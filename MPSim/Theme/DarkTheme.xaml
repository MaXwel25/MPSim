<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="WindowBackground" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="CardBackground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextPrimary" Color="#212121"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#757575"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#2196F3"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="HoverBrush" Color="#E3F2FD"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#4CAF50"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#FF9800"/>
    <SolidColorBrush x:Key="DangerBrush" Color="#F44336"/>
    <Style TargetType="Border" x:Key="CardStyle">
        <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="15"/>
    </Style>
</ResourceDictionary>