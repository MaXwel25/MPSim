<Window x:Class="MPSim.UI.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Конфигурация симуляции" Height="560" Width="680"
        WindowStartupLocation="CenterOwner"
	Background="{DynamicResource MaterialDesignPaper}"
	TextElement.Foreground="{DynamicResource MaterialDesignBody}"
	TextElement.FontWeight="Regular"
	TextElement.FontSize="13"
	FontFamily="{DynamicResource MaterialDesignFont}">

	<Grid Margin="24">
		<Grid.RowDefinitions>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto"
                      materialDesign:ScrollViewerAssist.IsAutoHideEnabled="True">
			<StackPanel>

				<materialDesign:Card Margin="0,0,0,16" Padding="16"
                                     UniformCornerRadius="8"
                                     materialDesign:ElevationAssist.Elevation="Dp1">
					<GroupBox Header="Параметры симуляции"
                              Style="{StaticResource MaterialDesignGroupBox}"
                              materialDesign:ColorZoneAssist.Mode="Standard">
						<Grid Margin="0,8,0,0">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>

							<StackPanel Grid.Column="0" Margin="0,0,8,0">
								<TextBlock Text="Количество фаз (k)"
                                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                           Margin="0,0,0,4"/>
								<TextBox x:Name="txtPhases" Text="3"
                                         Style="{StaticResource MaterialDesignTextBox}"
                                         materialDesign:HintAssist.Hint="Например: 3"/>
							</StackPanel>

							<StackPanel Grid.Column="1" Margin="4,0,4,0">
								<TextBlock Text="Количество заданий (N)"
                                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                           Margin="0,0,0,4"/>
								<TextBox x:Name="txtJobs" Text="100"
                                         Style="{StaticResource MaterialDesignTextBox}"
                                         materialDesign:HintAssist.Hint="Например: 100"/>
							</StackPanel>

							<StackPanel Grid.Column="2" Margin="8,0,0,0">
								<TextBlock Text="Количество прогонов"
                                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                           Margin="0,0,0,4"/>
								<TextBox x:Name="txtRuns" Text="10"
                                         Style="{StaticResource MaterialDesignTextBox}"
                                         materialDesign:HintAssist.Hint="Например: 10"/>
							</StackPanel>
						</Grid>
					</GroupBox>
				</materialDesign:Card>

				<materialDesign:Card Margin="0,0,0,16" Padding="16"
                                     UniformCornerRadius="8"
                                     materialDesign:ElevationAssist.Elevation="Dp1">
					<GroupBox Header="Параметры распределений"
                              Style="{StaticResource MaterialDesignGroupBox}">
						<Grid Margin="0,8,0,0">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>

							<StackPanel Grid.Column="0" Margin="0,0,8,0">
								<TextBlock Text="Интенсивность потока (λ)"
                                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                           Margin="0,0,0,4"/>
								<TextBox x:Name="txtLambda" Text="0.8"
                                         Style="{StaticResource MaterialDesignTextBox}"
                                         materialDesign:HintAssist.Hint="Например: 0.8"/>
							</StackPanel>

							<StackPanel Grid.Column="1" Margin="4,0,4,0">
								<TextBlock Text="Среднее время обработки (μ)"
                                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                           Margin="0,0,0,4"/>
								<TextBox x:Name="txtMu" Text="1.0"
                                         Style="{StaticResource MaterialDesignTextBox}"
                                         materialDesign:HintAssist.Hint="Например: 1.0"/>
							</StackPanel>

							<StackPanel Grid.Column="2" Margin="8,0,0,0">
								<TextBlock Text="СКО (σ)"
                                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                           Margin="0,0,0,4"/>
								<TextBox x:Name="txtSigma" Text="0.2"
                                         Style="{StaticResource MaterialDesignTextBox}"
                                         materialDesign:HintAssist.Hint="Например: 0.2"/>
							</StackPanel>
						</Grid>
					</GroupBox>
				</materialDesign:Card>

				<materialDesign:Card Margin="0,0,0,0" Padding="16"
                                     UniformCornerRadius="8"
                                     materialDesign:ElevationAssist.Elevation="Dp1">
					<GroupBox Header="Генератор и распределения"
                              Style="{StaticResource MaterialDesignGroupBox}">
						<Grid Margin="0,8,0,0">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>

							<StackPanel Grid.Column="0" Margin="0,0,8,0">
								<TextBlock Text="Интервалы поступления"
                                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                           Margin="0,0,0,4"/>
								<ComboBox x:Name="cbIntervalDist" SelectedIndex="0"
                                          Style="{StaticResource MaterialDesignComboBox}">
									<ComboBoxItem Content="Экспоненциальное"/>
									<ComboBoxItem Content="Равномерное"/>
									<ComboBoxItem Content="Нормальное"/>
								</ComboBox>
							</StackPanel>

							<StackPanel Grid.Column="1" Margin="4,0,4,0">
								<TextBlock Text="Время обработки"
                                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                           Margin="0,0,0,4"/>
								<ComboBox x:Name="cbProcessingDist" SelectedIndex="0"
                                          Style="{StaticResource MaterialDesignComboBox}">
									<ComboBoxItem Content="Нормальное"/>
									<ComboBoxItem Content="Экспоненциальное"/>
									<ComboBoxItem Content="Равномерное"/>
								</ComboBox>
							</StackPanel>

							<StackPanel Grid.Column="2" Margin="8,0,0,0">
								<TextBlock Text="Seed генератора"
                                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                           Margin="0,0,0,4"/>
								<TextBox x:Name="txtSeed" Text="42"
                                         Style="{StaticResource MaterialDesignTextBox}"
                                         materialDesign:HintAssist.Hint="Например: 42"/>
							</StackPanel>
						</Grid>
					</GroupBox>
				</materialDesign:Card>

			</StackPanel>
		</ScrollViewer>

		<StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
			<Button x:Name="btnCancel" Content="Отмена" Width="110" Margin="0,0,8,0"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Click="btnCancel_Click"/>
			<Button x:Name="btnApply" Content="Применить" Width="110"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Background="{DynamicResource PrimaryHueMidBrush}"
                    Foreground="{DynamicResource PrimaryHueMidForegroundBrush}"
                    Click="btnApply_Click"/>
		</StackPanel>
	</Grid>
</Window>