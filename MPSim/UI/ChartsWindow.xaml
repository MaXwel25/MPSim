<Window x:Class="MPSim.UI.ChartsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        Title="Визуализация результатов" Height="600" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackground}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Тип графика:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{DynamicResource TextPrimary}"/>
            <ComboBox x:Name="cbChartType" Width="200" SelectionChanged="cbChartType_SelectionChanged">
                <ComboBoxItem Content="Загрузка ФУ" IsSelected="True"/>
                <ComboBoxItem Content="Время ожидания"/>
                <ComboBoxItem Content="Простои ФУ"/>
                <ComboBoxItem Content="Пропускная способность"/>
            </ComboBox>
        </StackPanel>
        <Border Grid.Row="1" Background="{DynamicResource CardBackground}" CornerRadius="8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
            <ScottPlot:WpfPlot x:Name="MainPlot"/>
        </Border>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button x:Name="btnExport" Content="Экспорт PNG" Width="120" Background="{DynamicResource SuccessBrush}" Foreground="White" Margin="0,0,10,0" Click="btnExport_Click"/>
            <Button x:Name="btnClose" Content="Закрыть" Width="120" Click="btnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>