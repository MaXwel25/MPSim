<Window x:Class="MPSim.UI.ThemeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выбор темы" Height="250" Width="400"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackground}">
    <Grid Margin="30">
        <StackPanel>
            <TextBlock Text="Выберите оформление интерфейса" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,20" Foreground="{DynamicResource TextPrimary}"/>
            <ComboBox x:Name="cbTheme" Width="200" HorizontalAlignment="Center" Margin="0,0,0,20">
                <ComboBoxItem Content="Светлая тема" Tag="Light" IsSelected="True"/>
                <ComboBoxItem Content="Тёмная тема" Tag="Dark"/>
            </ComboBox>
            <Button x:Name="btnApplyTheme" Content="Применить" Width="150" Background="{DynamicResource AccentBrush}" Foreground="White" Click="btnApplyTheme_Click"/>
        </StackPanel>
    </Grid>
</Window>