<Window x:Class="MPSim.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="MPSim - Анализ многофазных систем" 
        Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesignPaper}"
        Foreground="{DynamicResource MaterialDesignBody}"
        FontFamily="{DynamicResource MaterialDesignFont}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <materialDesign:Card Grid.Row="0" Padding="12,10" Margin="0,0,0,12"
                             UniformCornerRadius="8"
                             materialDesign:ElevationAssist.Elevation="Dp1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🔬" FontSize="28" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="MPSim" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text="Многофазная система обработки данных" FontSize="11"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="btnSettings" Content="⚙️ Конфигурация" Width="161" Margin="0,0,8,0"
            Style="{StaticResource MaterialDesignFlatButton}"
            Foreground="{DynamicResource MaterialDesignBody}"
            Click="btnSettings_Click"/>

                    <Button x:Name="btnResults" Content="📊 Аналитика" Width="138" Margin="0,0,8,0"
            Style="{StaticResource MaterialDesignFlatButton}"
            Foreground="{DynamicResource MaterialDesignBody}"
            Click="btnResults_Click"/>

                    <Button x:Name="btnTheme" Content="🎨 Тема" Width="93"
            Style="{StaticResource MaterialDesignFlatButton}"
            Foreground="{DynamicResource MaterialDesignBody}"
            Click="btnTheme_Click"/>
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <materialDesign:Card Grid.Row="1" 
                             UniformCornerRadius="8"
                             materialDesign:ElevationAssist.Elevation="Dp1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="16,12,16,8">
                    <Button x:Name="btnStart" Content="▶ Запустить" Width="120" Margin="0,0,8,0"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="{StaticResource SuccessBrush}" Foreground="White"
                            Click="btnStart_Click"/>
                    <Button x:Name="btnStop" Content="⏹ Остановить" Width="142" Margin="0,0,8,0"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="{StaticResource DangerBrush}" Foreground="White"
                            Click="btnStop_Click" IsEnabled="False"/>
                    <Button x:Name="btnReset" Content="🔄 Сброс" Width="100" Margin="0,0,16,0"
                            Style="{StaticResource MaterialDesignOutlinedButton}" Click="btnReset_Click"/>

                    <ProgressBar x:Name="ProgressBar" Width="150" Height="20" Value="0"
                                 Style="{StaticResource MaterialDesignLinearProgressBar}"
                                 Visibility="Collapsed" Margin="0,0,16,0"/>

                    <TextBlock x:Name="txtStatus" Text="Готов к работе" VerticalAlignment="Center"
                               Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                </StackPanel>

                <Grid Grid.Row="1" x:Name="SimulationArea" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <materialDesign:Card Grid.Column="0" Margin="16,0,8,16" Padding="0"
                                         UniformCornerRadius="4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="📋 Задания" Padding="12,8" 
                                       FontWeight="Bold" Background="{DynamicResource PrimaryHueLightBrush}"
                                       Foreground="{DynamicResource PrimaryHueLightForegroundBrush}"/>
                            <DataGrid Grid.Row="1" x:Name="dgTasks" 
                                      Style="{StaticResource MaterialDesignDataGrid}"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                                    <DataGridTextColumn Header="Поступление" Binding="{Binding ArrivalTime, StringFormat=F2}" Width="90"/>
                                    <DataGridTextColumn Header="Ожидание" Binding="{Binding WaitTime, StringFormat=F2}" Width="90"/>
                                    <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </materialDesign:Card>

                    <materialDesign:Card Grid.Column="1" Margin="8,0,16,16" Padding="0"
                                         UniformCornerRadius="4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="⚙️ Фазы (ФУ)" Padding="12,8" 
                                       FontWeight="Bold" Background="{DynamicResource PrimaryHueLightBrush}"
                                       Foreground="{DynamicResource PrimaryHueLightForegroundBrush}"/>
                            <DataGrid Grid.Row="1" x:Name="dgPhases" 
                                      Style="{StaticResource MaterialDesignDataGrid}"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Фаза" Binding="{Binding Id}" Width="50"/>
                                    <DataGridTextColumn Header="Загрузка" Binding="{Binding Utilization, StringFormat=P1}" Width="80"/>
                                    <DataGridTextColumn Header="Простой" Binding="{Binding IdlePercent, StringFormat=P1}" Width="80"/>
                                    <DataGridTextColumn Header="Обработано" Binding="{Binding ProcessedCount}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </materialDesign:Card>
                </Grid>

                <StackPanel Grid.Row="1" x:Name="PlaceholderArea" 
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="🖥️" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    <TextBlock Text="Нажмите «Запустить» для начала симуляции" 
                               FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </materialDesign:Card>
    </Grid>
</Window>